# GeoSupply AI — Environment Variables
# Copy to .env and fill in values
# See Part_XI_API_Reference.md §11.11 for full documentation
#
# ⚠️  NEVER commit .env to version control
# ⚠️  Keys are phase-gated — you only need keys for your current phase
# ⚠️  Prefix: GEOSUPPLY_ on all keys for namespace isolation

# ═══════════════════════════════════════════════════════════════
# Phase 0-1: LLM & Infrastructure (REQUIRED from Day 1)
# ═══════════════════════════════════════════════════════════════

# Primary LLM — Groq (free: 14,400 req/day, 30 req/min)
GEOSUPPLY_GROQ_KEY=

# Local LLM fallback — Ollama
GEOSUPPLY_OLLAMA_URL=http://localhost:11434

# Emergency LLM — Claude (₹0.25/call, max 10/day hard limit)
GEOSUPPLY_CLAUDE_KEY=

# Vector DB — local persistent storage
GEOSUPPLY_CHROMADB_PATH=./data/chromadb

# SQLite — local event/cache storage
GEOSUPPLY_SQLITE_PATH=./data/geosupply.db

# Supabase — PostgreSQL (free: 500MB, 50K MAU)
GEOSUPPLY_SUPABASE_URL=
GEOSUPPLY_SUPABASE_KEY=

# ═══════════════════════════════════════════════════════════════
# Phase 2: Data Ingestion
# ═══════════════════════════════════════════════════════════════

# NewsAPI — 100 req/day, 1-month article history max
GEOSUPPLY_NEWSAPI_KEY=

# ACLED — free for researchers (registration takes 1-2 days)
GEOSUPPLY_ACLED_KEY=
GEOSUPPLY_ACLED_EMAIL=

# Telegram Bot — create via @BotFather
GEOSUPPLY_TELEGRAM_BOT_TOKEN=
GEOSUPPLY_TELEGRAM_API_ID=
GEOSUPPLY_TELEGRAM_API_HASH=

# Google Maps — $200/month free credits (~₹16,700)
GEOSUPPLY_GOOGLE_MAPS_KEY=

# ULIP — register at ulip.dpiit.gov.in (sandbox available)
GEOSUPPLY_ULIP_TOKEN=

# Google Drive — service account JSON path for backups
GEOSUPPLY_GDRIVE_SERVICE_ACCOUNT_JSON=./credentials/gdrive.json

# ═══════════════════════════════════════════════════════════════
# Phase 4-5: Intelligence & Cyber
# ═══════════════════════════════════════════════════════════════

# Shodan — 1 query credit/month free
GEOSUPPLY_SHODAN_KEY=

# GreyNoise — 50 req/day community tier
GEOSUPPLY_GREYNOISE_KEY=

# AlienVault OTX — unlimited (community)
GEOSUPPLY_OTX_KEY=

# NVD CVE — optional (5 req/30s without, 50 req/30s with)
GEOSUPPLY_NVD_KEY=

# ═══════════════════════════════════════════════════════════════
# Phase 10: Marketing & Outreach
# ═══════════════════════════════════════════════════════════════

# Twitter/X v2 — 10K reads/month free (marketing only)
GEOSUPPLY_TWITTER_BEARER_TOKEN=

# Email — SendGrid (100/day free) OR Resend (100/day free)
GEOSUPPLY_SENDGRID_KEY=
# GEOSUPPLY_RESEND_KEY=

# Reddit OSINT — 100 queries/min
GEOSUPPLY_REDDIT_CLIENT_ID=
GEOSUPPLY_REDDIT_SECRET=

# ═══════════════════════════════════════════════════════════════
# Phase 11: Security
# ═══════════════════════════════════════════════════════════════

# TOTP + JWT for AdminPortal
GEOSUPPLY_TOTP_SECRET=
GEOSUPPLY_JWT_SECRET_KEY=

# Event signing (HMAC-SHA256)
GEOSUPPLY_EVENT_SIGNING_MASTER_KEY=
GEOSUPPLY_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════
# Phase 15: FA v2 — World Monitor Integration
# ═══════════════════════════════════════════════════════════════

# OpenSky Network — ⚠️ MUST use OAuth2 (basic auth DEAD March 18 2026!)
# Register: https://opensky-network.org/ → OAuth2 client credentials
GEOSUPPLY_OPENSKY_CLIENT_ID=
GEOSUPPLY_OPENSKY_CLIENT_SECRET=

# AISStream — maritime vessel tracking (WebSocket)
GEOSUPPLY_AISSTREAM_KEY=

# Finnhub — 60 calls/min, 30 calls/sec max
GEOSUPPLY_FINNHUB_KEY=

# FRED — US economic data (unlimited, free registration)
GEOSUPPLY_FRED_KEY=

# EIA — energy/oil data (unlimited, free registration)
GEOSUPPLY_EIA_KEY=

# Cloudflare Radar — internet outage / BGP monitoring
GEOSUPPLY_CLOUDFLARE_RADAR_TOKEN=

# Wingbits — ADS-B aircraft enrichment (community)
GEOSUPPLY_WINGBITS_KEY=

# RSS2JSON — optional (10K req/day free without key)
GEOSUPPLY_RSS2JSON_KEY=

# ═══════════════════════════════════════════════════════════════
# Runtime Configuration (LOCKED values — do not change)
# ═══════════════════════════════════════════════════════════════

GEOSUPPLY_ENV=development
GEOSUPPLY_LOG_LEVEL=INFO
GEOSUPPLY_BUDGET_CAP_INR=500
GEOSUPPLY_HALLUCINATION_FLOOR=0.70
