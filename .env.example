# GeoSupply AI — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git

# === LLM APIs ===
GROQ_API_KEY=
CLAUDE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# === Database ===
SUPABASE_URL=
SUPABASE_KEY=
CHROMADB_PATH=./data/chromadb
SQLITE_PATH=./data/geosupply.db

# === Ingestion ===
NEWSAPI_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# === Google ===
GOOGLE_MAPS_API_KEY=
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/gdrive.json

# === Marketing ===
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
SENDGRID_API_KEY=

# === Security ===
TOTP_SECRET=
JWT_SECRET_KEY=
EVENT_SIGNING_MASTER_KEY=
ENCRYPTION_KEY=

# === Cyber Intel (P1-P3) ===
SHODAN_API_KEY=
NVD_API_KEY=

# === Runtime ===
GEOSUPPLY_ENV=development
GEOSUPPLY_LOG_LEVEL=INFO
GEOSUPPLY_BUDGET_CAP_INR=500
GEOSUPPLY_HALLUCINATION_FLOOR=0.70
